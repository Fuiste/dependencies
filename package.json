{
  "name": "@fuiste/dependencies",
  "version": "0.1.0",
  "description": "Type-safe, functional dependency composition for TypeScript",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:types": "tsc --noEmit -p tsconfig.types.json",
    "lint": "eslint . --ext .ts,.tsx,.js,.mjs,.cjs",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.mjs,.cjs --fix",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "prepublishOnly": "pnpm build",
    "test:watch": "vitest"
  },
  "keywords": [
    "dependency-injection",
    "typescript",
    "functional",
    "layer"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/node": "^24.3.1",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.2.0",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0",
    "vitest": "^3.2.4"
  }
}
